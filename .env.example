# .env.local template — salin file ini ke .env.local dan isi nilainya

# ─── Supabase (PostgreSQL) ────────────────────────────────────────────────────
# Dapatkan dari: supabase.com → project → Settings → Database → Connection String
#
# DATABASE_URL → pakai "Transaction pooler" (port 6543) untuk runtime/query
# DIRECT_URL   → pakai "Session pooler" atau "Direct connection" (port 5432) untuk migrasi
#
# Format Transaction pooler (untuk DATABASE_URL):
DATABASE_URL="postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Format Direct connection (untuk DIRECT_URL):
DIRECT_URL="postgresql://postgres.YOURPROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Vercel Blob ──────────────────────────────────────────────────────────────
# Dapatkan dari: vercel.com → project → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=""

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Dapatkan dari: resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Moodboard <noreply@yourdomain.com>"

# ─── Cron Secret ──────────────────────────────────────────────────────────────
# Random string — set juga di Vercel dashboard (Environment Variables)
CRON_SECRET=""

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
